@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix battinfo: <https://w3id.org/battinfo#> .
@prefix schema: <https://schema.org/> .

battinfo: a owl:Ontology ;
    rdfs:label "BattINFO application ontology"@en ;
    rdfs:comment "Application/profile ontology for BattINFO battery descriptor extensions and operational semantics."@en ;
    owl:imports <https://w3id.org/emmo/domain/battery> .
