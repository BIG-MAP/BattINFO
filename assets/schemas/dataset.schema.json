{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schema/dataset.schema.json",
  "title": "BattINFO Dataset (Schema.org-Aligned)",
  "description": "Canonical BattINFO dataset metadata using schema.org Dataset terms with minimal registry provenance extensions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "identifier",
        "name",
        "access_url"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/DatasetIri"
        },
        "short_id": {
          "$ref": "#/$defs/ShortId"
        },
        "identifier": {
          "$ref": "#/$defs/Identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "access_url": {
          "type": "string",
          "format": "uri"
        },
        "same_as": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "uniqueItems": true
        },
        "about": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AboutRef"
          },
          "uniqueItems": true
        },
        "additional_type": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1,
              "uniqueItems": true
            }
          ]
        },
        "license": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "version": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "creators": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PersonOrOrganization"
          },
          "minItems": 1
        },
        "publisher": {
          "$ref": "#/$defs/Organization"
        },
        "funders": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PersonOrOrganization"
          },
          "minItems": 1
        },
        "citations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Citation"
          }
        },
        "measurement_techniques": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "format": "uri"
              }
            ]
          },
          "uniqueItems": true
        },
        "measurement_methods": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "format": "uri"
              }
            ]
          },
          "uniqueItems": true
        },
        "variable_measured": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/VariableMeasured"
          }
        },
        "is_accessible_for_free": {
          "type": "boolean"
        },
        "conditions_of_access": {
          "type": "string"
        },
        "in_language": {
          "type": "string",
          "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
        },
        "created_at": {
          "$ref": "#/$defs/UnixTime"
        },
        "modified_at": {
          "$ref": "#/$defs/UnixTime"
        },
        "published_at": {
          "$ref": "#/$defs/UnixTime"
        },
        "temporal_coverage": {
          "type": "string"
        },
        "spatial_coverage": {
          "type": "string"
        },
        "distributions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DataDistribution"
          },
          "minItems": 1
        },
        "main_entity": {
          "anyOf": [
            {
              "$ref": "#/$defs/CsvwMainEntity"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/CsvwMainEntity"
              },
              "minItems": 1
            }
          ]
        },
        "is_based_on": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "uniqueItems": true
        },
        "included_in_data_catalog": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "string",
              "format": "uri"
            },
            {
              "$ref": "#/$defs/DataCatalog"
            }
          ]
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "retrieved_at"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "catalog",
            "measurement",
            "lab",
            "simulation",
            "external",
            "manual",
            "other"
          ]
        },
        "source_name": {
          "type": "string"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "citation": {
          "type": "string",
          "format": "uri"
        },
        "citation_doi": {
          "type": "string",
          "pattern": "^10\\.\\d{4,9}/[-._;()/:A-Za-z0-9]+$"
        },
        "source_file": {
          "type": "string"
        },
        "source_sheet": {
          "type": "string"
        },
        "source_row": {
          "type": "integer",
          "minimum": 1
        },
        "source_workbook_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "source_dataset_key": {
          "type": "string"
        },
        "ingest_status": {
          "type": "string",
          "enum": [
            "ready",
            "needs_review",
            "blocked"
          ]
        },
        "quality_flags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "retrieved_at": {
          "$ref": "#/$defs/UnixTime"
        },
        "curated_by": {
          "type": "string"
        },
        "workflow_version": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "funding": {
      "$ref": "#/$defs/Funding"
    },
    "contributor": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Person"
      },
      "minItems": 1,
      "description": "People who contributed this record to the platform (attribution/provenance). Each is a schema:Person; an ORCID may be given in same_as. Distinct from data authorship (creators)."
    }
  },
  "$defs": {
    "UnixTime": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp in whole seconds since 1970-01-01T00:00:00Z."
    },
    "ShortId": {
      "type": "string",
      "pattern": "^[0-9a-hjkmnp-tv-z]{6,16}$"
    },
    "DatasetIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/dataset/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "CellTypeIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/cell/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "CellIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/cell/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "TestIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/test/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "AboutRef": {
      "anyOf": [
        {
          "$ref": "#/$defs/CellTypeIri"
        },
        {
          "$ref": "#/$defs/CellIri"
        },
        {
          "$ref": "#/$defs/TestIri"
        },
        {
          "type": "string",
          "format": "uri"
        }
      ]
    },
    "Identifier": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/PropertyValue"
        },
        {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "$ref": "#/$defs/PropertyValue"
              }
            ]
          },
          "minItems": 1
        }
      ]
    },
    "PropertyValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "property_id",
        "value"
      ],
      "properties": {
        "property_id": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Person": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "Person"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "given_name": {
          "type": "string",
          "minLength": 1
        },
        "family_name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "same_as": {
          "type": "string",
          "format": "uri"
        },
        "affiliation": {
          "$ref": "#/$defs/Organization"
        }
      }
    },
    "Organization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "Organization"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "same_as": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "PersonOrOrganization": {
      "anyOf": [
        {
          "$ref": "#/$defs/Person"
        },
        {
          "$ref": "#/$defs/Organization"
        }
      ]
    },
    "DataCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "DataCatalog"
        },
        "id": {
          "type": "string",
          "format": "uri"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "same_as": {
          "type": "string",
          "format": "uri"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "Citation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "dataset",
            "article",
            "software",
            "other"
          ]
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "doi": {
          "type": "string"
        },
        "citation_key": {
          "type": "string"
        }
      }
    },
    "Checksum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "sha256",
            "sha512",
            "md5",
            "other"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "DataDistribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_url",
        "encoding_format"
      ],
      "properties": {
        "type": {
          "const": "DataDownload"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "content_url": {
          "type": "string",
          "format": "uri"
        },
        "encoding_format": {
          "type": "string",
          "minLength": 1
        },
        "content_size": {
          "type": "string"
        },
        "checksum": {
          "$ref": "#/$defs/Checksum"
        },
        "access_level": {
          "type": "string",
          "enum": [
            "open",
            "restricted",
            "embargoed",
            "closed",
            "unknown"
          ]
        },
        "role": {
          "type": "string",
          "description": "Role of this file within the dataset: a normalised 'processed' file or the original 'raw' instrument file kept for provenance.",
          "enum": [
            "processed",
            "raw",
            "report",
            "metadata",
            "other"
          ]
        },
        "conditions": {
          "type": "object",
          "description": "Per-file measurement conditions (e.g. {\"soc\": 0.5} for EIS files split by SOC).",
          "patternProperties": {
            "^[a-z][a-z0-9_]*$": {}
          },
          "additionalProperties": false
        }
      }
    },
    "CsvwTable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "url",
        "table_schema"
      ],
      "properties": {
        "type": {
          "const": "Table"
        },
        "id": {
          "type": "string",
          "format": "uri"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "table_schema": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "$ref": "#/$defs/CsvwTableSchema"
            }
          ]
        }
      }
    },
    "CsvwTableGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "table"
      ],
      "properties": {
        "type": {
          "const": "TableGroup"
        },
        "id": {
          "type": "string",
          "format": "uri"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "table": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CsvwTable"
          },
          "minItems": 1
        }
      }
    },
    "CsvwMainEntity": {
      "anyOf": [
        {
          "$ref": "#/$defs/CsvwTable"
        },
        {
          "$ref": "#/$defs/CsvwTableGroup"
        }
      ]
    },
    "CsvwTableColumn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "titles": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            }
          ]
        },
        "description": {
          "type": "string"
        },
        "datatype": {
          "type": "string",
          "minLength": 1
        },
        "unit_text": {
          "type": "string",
          "minLength": 1
        },
        "same_as": {
          "type": "string",
          "format": "uri"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "CsvwTableSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "columns"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uri"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "primary_key": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            }
          ]
        },
        "columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CsvwTableColumn"
          },
          "minItems": 1
        }
      }
    },
    "VariableMeasured": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "unit_text": {
          "type": "string"
        },
        "same_as": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "Funding": {
      "type": "object",
      "additionalProperties": false,
      "description": "Funding project (grant) under which the record was produced. Maps to schema:funding / schema:Grant in JSON-LD.",
      "required": [
        "identifier"
      ],
      "properties": {
        "type": {
          "const": "Grant"
        },
        "id": {
          "type": "string",
          "format": "uri"
        },
        "identifier": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "acronym": {
          "type": "string"
        },
        "program": {
          "type": "string"
        },
        "funder": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name"
          ],
          "properties": {
            "type": {
              "const": "Organization"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "same_as": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      }
    }
  }
}
