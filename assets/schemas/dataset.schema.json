{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schema/dataset.schema.json",
  "title": "BattINFO Dataset (Schema.org-Aligned)",
  "description": "Canonical BattINFO dataset metadata using schema.org Dataset terms with minimal registry provenance extensions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "identifier",
        "name",
        "url"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/DatasetIri"
        },
        "short_id": {
          "$ref": "#/$defs/ShortId"
        },
        "identifier": {
          "$ref": "#/$defs/Identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sameAs": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "uniqueItems": true
        },
        "about": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AboutRef"
          },
          "uniqueItems": true
        },
        "additionalType": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1,
              "uniqueItems": true
            }
          ]
        },
        "license": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "version": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "creator": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PersonOrOrganization"
          },
          "minItems": 1
        },
        "publisher": {
          "$ref": "#/$defs/Organization"
        },
        "citation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Citation"
          }
        },
        "measurementTechnique": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "format": "uri"
              }
            ]
          },
          "uniqueItems": true
        },
        "measurementMethod": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "format": "uri"
              }
            ]
          },
          "uniqueItems": true
        },
        "variableMeasured": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/VariableMeasured"
          }
        },
        "isAccessibleForFree": {
          "type": "boolean"
        },
        "conditionsOfAccess": {
          "type": "string"
        },
        "inLanguage": {
          "type": "string",
          "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
        },
        "dateCreated": {
          "$ref": "#/$defs/UnixTime"
        },
        "dateModified": {
          "$ref": "#/$defs/UnixTime"
        },
        "datePublished": {
          "$ref": "#/$defs/UnixTime"
        },
        "temporalCoverage": {
          "type": "string"
        },
        "spatialCoverage": {
          "type": "string"
        },
        "distribution": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DataDistribution"
          },
          "minItems": 1
        },
        "isBasedOn": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "uniqueItems": true
        },
        "includedInDataCatalog": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "string",
              "format": "uri"
            }
          ]
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "retrieved_at"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "catalog",
            "measurement",
            "lab",
            "simulation",
            "external",
            "manual",
            "other"
          ]
        },
        "source_name": {
          "type": "string"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "source_file": {
          "type": "string"
        },
        "source_sheet": {
          "type": "string"
        },
        "source_row": {
          "type": "integer",
          "minimum": 1
        },
        "source_workbook_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "source_dataset_key": {
          "type": "string"
        },
        "ingest_status": {
          "type": "string",
          "enum": [
            "ready",
            "needs_review",
            "blocked"
          ]
        },
        "quality_flags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "retrieved_at": {
          "$ref": "#/$defs/UnixTime"
        },
        "curated_by": {
          "type": "string"
        },
        "workflow_version": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "UnixTime": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp in whole seconds since 1970-01-01T00:00:00Z."
    },
    "ShortId": {
      "type": "string",
      "pattern": "^[0-9a-hjkmnp-tv-z]{6,16}$"
    },
    "DatasetIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/dataset/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "CellTypeIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/cell-type/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "CellIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/cell/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "TestIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/test/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "AboutRef": {
      "anyOf": [
        {
          "$ref": "#/$defs/CellTypeIri"
        },
        {
          "$ref": "#/$defs/CellIri"
        },
        {
          "$ref": "#/$defs/TestIri"
        },
        {
          "type": "string",
          "format": "uri"
        }
      ]
    },
    "Identifier": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/PropertyValue"
        },
        {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "$ref": "#/$defs/PropertyValue"
              }
            ]
          },
          "minItems": 1
        }
      ]
    },
    "PropertyValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "property_id",
        "value"
      ],
      "properties": {
        "property_id": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Person": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "Person"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "affiliation": {
          "$ref": "#/$defs/Organization"
        }
      }
    },
    "Organization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "Organization"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "PersonOrOrganization": {
      "anyOf": [
        {
          "$ref": "#/$defs/Person"
        },
        {
          "$ref": "#/$defs/Organization"
        }
      ]
    },
    "Citation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "dataset",
            "article",
            "software",
            "other"
          ]
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "doi": {
          "type": "string"
        },
        "citation_key": {
          "type": "string"
        }
      }
    },
    "Checksum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "sha256",
            "sha512",
            "md5",
            "other"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "DataDistribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contentUrl",
        "encodingFormat"
      ],
      "properties": {
        "type": {
          "const": "DataDownload"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "contentUrl": {
          "type": "string",
          "format": "uri"
        },
        "encodingFormat": {
          "type": "string",
          "minLength": 1
        },
        "contentSize": {
          "type": "string"
        },
        "checksum": {
          "$ref": "#/$defs/Checksum"
        },
        "accessLevel": {
          "type": "string",
          "enum": [
            "open",
            "restricted",
            "embargoed",
            "closed",
            "unknown"
          ]
        }
      }
    },
    "VariableMeasured": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "unit_text": {
          "type": "string"
        },
        "sameAs": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
