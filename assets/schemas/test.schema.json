{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schema/test.schema.json",
  "title": "BattINFO Test",
  "description": "Canonical BattINFO test metadata linking a physical cell instance to a concrete test activity and its datasets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "test",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "cell_id",
        "name",
        "kind"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/TestIri"
        },
        "short_id": {
          "$ref": "#/$defs/ShortId"
        },
        "identifier": {
          "type": "string",
          "minLength": 1
        },
        "cell_id": {
          "$ref": "#/$defs/CellIri"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "protocol_id": {
          "$ref": "#/$defs/SpecIri"
        },
        "description": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "cycling",
            "capacity_check",
            "rate_capability",
            "quasi_ocv",
            "hppc",
            "ici",
            "gitt",
            "dcir",
            "eis",
            "impedance",
            "calendar_ageing",
            "formation",
            "rpt",
            "field",
            "duty_cycle",
            "wltp",
            "nedc",
            "sem",
            "characterization",
            "other"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "running",
            "completed",
            "aborted",
            "other"
          ]
        },
        "protocol_name": {
          "type": "string"
        },
        "protocol_url": {
          "type": "string",
          "format": "uri"
        },
        "instrument_name": {
          "type": "string"
        },
        "started_at": {
          "$ref": "#/$defs/UnixTime"
        },
        "ended_at": {
          "$ref": "#/$defs/UnixTime"
        },
        "dataset_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DatasetIri"
          },
          "uniqueItems": true
        },
        "conditions": {
          "type": "object",
          "description": "Test conditions and parameters (temperature, voltage window, C-rate, frequency range, etc.).",
          "patternProperties": {
            "^[a-z][a-z0-9_]*$": {}
          },
          "additionalProperties": false
        },
        "conformance": {
          "type": "object",
          "description": "Assessment of how well this record followed the spec that governs it.",
          "additionalProperties": false,
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "conformant",
                "non-conformant",
                "unknown"
              ]
            },
            "note": {
              "type": "string",
              "description": "Free-text summary of the assessment."
            },
            "deviations": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "category"
                ],
                "properties": {
                  "category": {
                    "type": "string",
                    "enum": [
                      "power_outage",
                      "equipment_failure",
                      "temperature_excursion",
                      "software_error",
                      "operator_intervention",
                      "premature_termination",
                      "communication_loss",
                      "parameter_drift",
                      "setpoint_deviation",
                      "calibration_issue",
                      "out_of_tolerance",
                      "dimensional",
                      "other"
                    ],
                    "description": "Broad classification of the deviation."
                  },
                  "type": {
                    "type": "string",
                    "description": "Specific deviation label within the category (free text)."
                  },
                  "description": {
                    "type": "string"
                  },
                  "occurred_at": {
                    "type": [
                      "integer",
                      "string"
                    ]
                  },
                  "duration_s": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "step_index": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "impact": {
                    "type": "string",
                    "enum": [
                      "minor",
                      "moderate",
                      "major"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "retrieved_at"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "measurement",
            "lab",
            "simulation",
            "manual",
            "other"
          ]
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "citation": {
          "type": "string",
          "format": "uri"
        },
        "citation_doi": {
          "type": "string",
          "pattern": "^10\\.\\d{4,9}/[-._;()/:A-Za-z0-9]+$"
        },
        "source_file": {
          "type": "string"
        },
        "retrieved_at": {
          "$ref": "#/$defs/UnixTime"
        },
        "workflow_version": {
          "type": "string"
        },
        "source_name": {
          "type": "string"
        },
        "file_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "curated_by": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "description": "Actionable-layer links to runnable protocol/vendor files produced by or executed in this test.",
      "items": {
        "$ref": "#/$defs/Artifact"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "funding": {
      "$ref": "#/$defs/Funding"
    },
    "contributor": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Person"
      },
      "minItems": 1,
      "description": "People who contributed this record to the platform (attribution/provenance). Each is a schema:Person; an ORCID may be given in same_as. Distinct from data authorship (creators)."
    }
  },
  "$defs": {
    "Artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "format",
        "locator"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "source_protocol",
            "executed_protocol",
            "vendor_export",
            "simulation_input",
            "other"
          ]
        },
        "format": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "media_type": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "byte_size": {
          "type": "integer",
          "minimum": 0
        },
        "conforms_to": {
          "type": "string"
        },
        "generated": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "generated_from": {
          "type": "string"
        }
      }
    },
    "UnixTime": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp in whole seconds since 1970-01-01T00:00:00Z."
    },
    "ShortId": {
      "type": "string",
      "pattern": "^[0-9a-hjkmnp-tv-z]{6,16}$"
    },
    "CellIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/cell/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "DatasetIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/dataset/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "TestIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/test/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "SpecIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/spec/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "Funding": {
      "type": "object",
      "additionalProperties": false,
      "description": "Funding project (grant) under which the record was produced. Maps to schema:funding / schema:Grant in JSON-LD.",
      "required": [
        "identifier"
      ],
      "properties": {
        "type": {
          "const": "Grant"
        },
        "id": {
          "type": "string",
          "format": "uri"
        },
        "identifier": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "acronym": {
          "type": "string"
        },
        "program": {
          "type": "string"
        },
        "funder": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name"
          ],
          "properties": {
            "type": {
              "const": "Organization"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "same_as": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      }
    },
    "Organization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "Organization"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "same_as": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "Person": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "Person"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "given_name": {
          "type": "string",
          "minLength": 1
        },
        "family_name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "same_as": {
          "type": "string",
          "format": "uri"
        },
        "affiliation": {
          "$ref": "#/$defs/Organization"
        }
      }
    }
  }
}
