{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schema/modules/components/electrode.schema.json",
  "title": "Electrode",
  "description": "Electrode model composed of coating, current collector, and optional properties.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "coating": {
      "$ref": "electrode-coating.schema.json"
    },
    "current_collector": {
      "$ref": "current-collector.schema.json"
    },
    "manufacturer": {
      "type": "string"
    },
    "supplier": {
      "type": "string"
    },
    "product_id": {
      "type": "string"
    },
    "property": {
      "$ref": "../common/quantitative-properties.schema.json"
    },
    "comment": {
      "type": "string"
    },
    "tab": {
      "type": "object",
      "title": "CurrentCollectorTab",
      "description": "Electrode current-collector tab (width, thickness, length, weld_width, tape_width)."
    }
  },
  "anyOf": [
    {
      "required": [
        "coating"
      ]
    },
    {
      "required": [
        "current_collector"
      ]
    },
    {
      "required": [
        "property"
      ]
    }
  ]
}
