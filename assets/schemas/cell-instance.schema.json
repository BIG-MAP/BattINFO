{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schema/cell-instance.schema.json",
  "title": "BattINFO Cell Instance",
  "description": "Physical cell instance derived from a cell type.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cell_instance",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
    },
    "cell_instance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type_id"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/CellIri"
        },
        "type_id": {
          "$ref": "#/$defs/SpecIri"
        },
        "short_id": {
          "$ref": "#/$defs/ShortId"
        },
        "serial_number": {
          "type": "string"
        },
        "batch_id": {
          "type": "string"
        },
        "grade": {
          "type": "string",
          "description": "Quality grade assigned to this cell (e.g. 'A', 'B', 'C', 'reject')."
        },
        "manufactured_at": {
          "$ref": "#/$defs/FlexDate",
          "description": "Production date. ISO 8601 string (YYYY-MM-DD, YYYY-MM) or Unix timestamp."
        },
        "expires_at": {
          "$ref": "#/$defs/FlexDate",
          "description": "Expiration / best-before date. ISO 8601 string (YYYY-MM-DD, YYYY-MM) or Unix timestamp."
        },
        "service_start_date": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 date when the battery was first put into service."
        },
        "battery_status": {
          "type": "string",
          "enum": [
            "original",
            "repurposed",
            "re-used",
            "remanufactured",
            "waste"
          ],
          "description": "Current status of the battery per EU Battery Regulation Annex XIII."
        },
        "dpp_status": {
          "type": "string",
          "enum": [
            "active",
            "archived",
            "inactive",
            "marked-for-deletion"
          ],
          "description": "Status of this digital product passport record."
        },
        "supersedes": {
          "$ref": "#/$defs/CellIri",
          "description": "IRI of the previous cell record this passport replaces, e.g. after repurposing."
        }
      }
    },
    "measured": {
      "$ref": "cell-canonical.schema.json#/$defs/SpecSet"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "measurement",
            "lab",
            "bms",
            "other"
          ]
        },
        "source_url": {
          "oneOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "citation": {
          "type": "string",
          "format": "uri"
        },
        "citation_doi": {
          "type": "string",
          "pattern": "^10\\.\\d{4,9}/[-._;()/:A-Za-z0-9]+$"
        },
        "retrieved_at": {
          "$ref": "#/$defs/UnixTime"
        }
      }
    },
    "datasets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DatasetLink"
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "UnixTime": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp in whole seconds since 1970-01-01T00:00:00Z."
    },
    "FlexDate": {
      "oneOf": [
        {"$ref": "#/$defs/UnixTime"},
        {"type": "string", "description": "ISO 8601 date string (YYYY-MM-DD or YYYY-MM)."}
      ]
    },
    "ShortId": {
      "type": "string",
      "pattern": "^[0-9a-hjkmnp-tv-z]{6,16}$"
    },
    "CellIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/cell/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "DatasetIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/dataset/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "DatasetLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/DatasetIri"
        },
        "role": {
          "type": "string",
          "enum": [
            "raw",
            "processed",
            "report",
            "metadata",
            "other"
          ]
        }
      }
    },
    "SpecIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/spec/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    }
  }
}
