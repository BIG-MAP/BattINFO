@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt:  <http://qudt.org/schema/qudt/> .
@prefix battery:         <https://w3id.org/emmo/domain/battery#> .
@prefix electrochemistry:<https://w3id.org/emmo/domain/electrochemistry#> .
@prefix emmo:            <https://w3id.org/emmo#> .
@prefix battinfo:        <https://w3id.org/battinfo/> .
@prefix shapes:          <https://w3id.org/battinfo/shapes/> .

# ── Plausibility shapes for cell-type spec quantities ─────────────────────────
#
# These shapes apply to the *quantity nodes* that are values of cell-spec
# properties in the BattINFO JSON-LD output (produced by
# battinfo.jsonld.cell_spec_to_jsonld).  Each quantity node has:
#
#   <spec-IRI>  <property-IRI>  [ qudt:value <num> ; qudt:unit <unit-IRI> ] .
#
# SHACL sh:targetObjectsOf selects the blank node objects; sh:property then
# constrains qudt:value on those nodes.
#
# Bounds are intentionally loose (order-of-magnitude sanity only) so that
# legitimate edge-case cells (ultra-high-capacity, miniature coin cells, etc.)
# are not incorrectly flagged.  Unit-conditional bounds are noted in comments
# but not enforced at this level (the Python semantic layer handles those).

# ── Voltages ──────────────────────────────────────────────────────────────────

shapes:NominalVoltageValueShape a sh:NodeShape ;
    sh:targetObjectsOf electrochemistry:electrochemistry_639b844a_e801_436b_985d_28926129ead6 ;
    sh:property [
        sh:path      qudt:value ;
        sh:minInclusive 0.3 ;
        sh:maxInclusive 5.5 ;
        sh:severity  sh:Warning ;
        sh:message   "Nominal voltage (V) should be in [0.3, 5.5]. Check for decimal-shift errors."
    ] .

shapes:ChargingVoltageValueShape a sh:NodeShape ;
    sh:targetObjectsOf electrochemistry:electrochemistry_79a9e1be_35b0_4c3c_8087_b5f967ca0e87 ;
    sh:property [
        sh:path      qudt:value ;
        sh:minInclusive 0.3 ;
        sh:maxInclusive 6.0 ;
        sh:severity  sh:Warning ;
        sh:message   "Charging voltage (V) should be in [0.3, 6.0]. Check for decimal-shift errors."
    ] .

shapes:DischargingCutoffVoltageValueShape a sh:NodeShape ;
    sh:targetObjectsOf electrochemistry:electrochemistry_534dd59c_904c_45d9_8550_ae9d2eb6bbc9 ;
    sh:property [
        sh:path      qudt:value ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 5.0 ;
        sh:severity  sh:Warning ;
        sh:message   "Discharging cutoff voltage (V) should be in [0.0, 5.0]."
    ] .

shapes:ChargingCutoffVoltageValueShape a sh:NodeShape ;
    sh:targetObjectsOf electrochemistry:electrochemistry_6dcd5baf_58cd_43f5_a692_51508e036c88 ;
    sh:property [
        sh:path      qudt:value ;
        sh:minInclusive 1.0 ;
        sh:maxInclusive 6.0 ;
        sh:severity  sh:Warning ;
        sh:message   "Charging cutoff voltage (V) should be in [1.0, 6.0]."
    ] .

# ── Capacity ──────────────────────────────────────────────────────────────────
# (nominal, minimum, rated, typical all use the same IRI)

shapes:CapacityValueShape a sh:NodeShape ;
    sh:targetObjectsOf electrochemistry:electrochemistry_8abde9d0_84f6_4b4f_a87e_86028a397100 ;
    sh:property [
        sh:path      qudt:value ;
        sh:minExclusive 0.0 ;
        sh:severity  sh:Warning ;
        sh:message   "Capacity value must be positive."
    ] .

# ── Energy ────────────────────────────────────────────────────────────────────
# (nominal, typical, rated, certified-usable all use same IRI)

shapes:EnergyValueShape a sh:NodeShape ;
    sh:targetObjectsOf electrochemistry:electrochemistry_19e27aa3_0970_43a6_86d3_e3cdd956134d ;
    sh:property [
        sh:path      qudt:value ;
        sh:minExclusive 0.0 ;
        sh:severity  sh:Warning ;
        sh:message   "Energy value must be positive."
    ] .

# ── Specific energy / energy density ─────────────────────────────────────────

shapes:SpecificEnergyValueShape a sh:NodeShape ;
    sh:targetObjectsOf emmo:EMMO_e218c625_6a39_47a9_8d08_a2ef41c152a9 ;
    sh:property [
        sh:path      qudt:value ;
        sh:minInclusive 1.0 ;
        sh:maxInclusive 1000.0 ;
        sh:severity  sh:Warning ;
        sh:message   "Specific energy (Wh/kg) should be in [1, 1000] for single cells."
    ] .

shapes:EnergyDensityValueShape a sh:NodeShape ;
    sh:targetObjectsOf electrochemistry:electrochemistry_4aa1b96e_44a0_4b1a_a0ac_723d0223d80b ;
    sh:property [
        sh:path      qudt:value ;
        sh:minInclusive 1.0 ;
        sh:maxInclusive 2500.0 ;
        sh:severity  sh:Warning ;
        sh:message   "Energy density (Wh/L) should be in [1, 2500] for single cells."
    ] .

