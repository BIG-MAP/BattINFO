{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schema/dataset.schema.json",
  "title": "BattINFO Dataset",
  "description": "Canonical dataset metadata with BattINFO identifier policy constraints.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "dataset", "provenance"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": { "$ref": "#/$defs/DatasetIri" },
        "short_id": { "$ref": "#/$defs/ShortId" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "license": { "type": "string" },
        "format": { "type": "string" },
        "access_url": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ]
        },
        "download_url": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ]
        },
        "created_at": { "type": "string", "format": "date-time" },
        "checksum": { "$ref": "#/$defs/Checksum" },
        "related_entities": { "$ref": "#/$defs/RelatedEntities" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "retrieved_at"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["measurement", "lab", "simulation", "external", "other"]
        },
        "source_url": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ]
        },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "curated_by": { "type": "string" }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "ShortId": {
      "type": "string",
      "pattern": "^[0-9a-hjkmnp-tv-z]{6,16}$"
    },
    "DatasetIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/dataset/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "CellIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/cell/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "TestIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/test/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "Checksum": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["sha256", "sha512", "md5", "other"]
        },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "RelatedEntities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cell_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/CellIri" },
          "uniqueItems": true
        },
        "test_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/TestIri" },
          "uniqueItems": true
        }
      }
    }
  }
}
