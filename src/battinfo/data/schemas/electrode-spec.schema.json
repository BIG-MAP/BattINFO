{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schema/electrode-spec.schema.json",
  "title": "BattINFO Electrode Spec",
  "description": "Reusable electrode specification (coating + current collector). The 'spec' half of the electrode-spec + electrode pair; references material-specs by IRI.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "electrode_spec",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
    },
    "electrode_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/ComponentSpecIri"
        },
        "short_id": {
          "$ref": "#/$defs/ShortId"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "polarity": {
          "type": "string",
          "enum": [
            "positive",
            "negative",
            "unknown"
          ]
        },
        "coating": {
          "$ref": "modules/components/electrode-coating.schema.json"
        },
        "current_collector": {
          "$ref": "modules/components/current-collector.schema.json"
        },
        "tab": {
          "type": "object",
          "title": "CurrentCollectorTab",
          "description": "Electrode current-collector tab (width, thickness, length, weld_width, tape_width)."
        },
        "manufacturer": {
          "$ref": "#/$defs/OrgRef"
        },
        "supplier": {
          "$ref": "#/$defs/OrgRef"
        },
        "product_id": {
          "type": "string"
        },
        "property": {
          "$ref": "modules/common/quantitative-properties.schema.json"
        },
        "comment": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "ComponentSpecIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/electrode-spec/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "ShortId": {
      "type": "string",
      "pattern": "^[0-9a-hjkmnp-tv-z]{6,16}$"
    },
    "UnixTime": {
      "type": "integer",
      "minimum": 0
    },
    "OrganizationIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/organization/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "Organization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "Organization"
        },
        "id": {
          "$ref": "#/$defs/OrganizationIri"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "OrgRef": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/Organization"
        }
      ]
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "datasheet",
            "manufacturer",
            "measurement",
            "lab",
            "literature",
            "manual",
            "other"
          ]
        },
        "source_name": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        },
        "source_url": {
          "oneOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "citation": {
          "type": "string",
          "format": "uri"
        },
        "citation_doi": {
          "type": "string",
          "pattern": "^10\\.\\d{4,9}/[-._;()/:A-Za-z0-9]+$"
        },
        "retrieved_at": {
          "$ref": "#/$defs/UnixTime"
        },
        "battinfo_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
        }
      }
    }
  }
}
