{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schema/cell-instance.schema.json",
  "title": "BattINFO Cell Instance",
  "description": "Physical cell instance derived from a cell type.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cell_instance",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
    },
    "cell_instance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "cell_spec_id"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/CellIri"
        },
        "cell_spec_id": {
          "$ref": "#/$defs/SpecIri"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name / label for this cell (e.g. a lab batch ID). The primary identifier; usually present even without a manufacturer serial number."
        },
        "short_id": {
          "$ref": "#/$defs/ShortId"
        },
        "serial_number": {
          "type": "string",
          "description": "Manufacturer serial number (unique within the product model); optional."
        },
        "batch_id": {
          "type": "string"
        },
        "grade": {
          "type": "string",
          "description": "Quality grade assigned to this cell (e.g. 'A', 'B', 'C', 'reject')."
        },
        "manufactured_at": {
          "$ref": "#/$defs/FlexDate",
          "description": "Production date. ISO 8601 string (YYYY-MM-DD, YYYY-MM) or Unix timestamp."
        },
        "expires_at": {
          "$ref": "#/$defs/FlexDate",
          "description": "Expiration / best-before date. ISO 8601 string (YYYY-MM-DD, YYYY-MM) or Unix timestamp."
        },
        "service_start_date": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 date when the battery was first put into service."
        },
        "battery_status": {
          "type": "string",
          "enum": [
            "original",
            "repurposed",
            "re-used",
            "remanufactured",
            "waste"
          ],
          "description": "Current status of the battery per EU Battery Regulation Annex XIII."
        },
        "dpp_status": {
          "type": "string",
          "enum": [
            "active",
            "archived",
            "inactive",
            "marked-for-deletion"
          ],
          "description": "Status of this digital product passport record."
        },
        "supersedes": {
          "$ref": "#/$defs/CellIri",
          "description": "IRI of the previous cell record this passport replaces, e.g. after repurposing."
        },
        "conformance": {
          "type": "object",
          "description": "Assessment of how well this record followed the spec that governs it.",
          "additionalProperties": false,
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "conformant",
                "non-conformant",
                "unknown"
              ]
            },
            "note": {
              "type": "string",
              "description": "Free-text summary of the assessment."
            },
            "deviations": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "category"
                ],
                "properties": {
                  "category": {
                    "type": "string",
                    "enum": [
                      "power_outage",
                      "equipment_failure",
                      "temperature_excursion",
                      "software_error",
                      "operator_intervention",
                      "premature_termination",
                      "communication_loss",
                      "parameter_drift",
                      "setpoint_deviation",
                      "calibration_issue",
                      "out_of_tolerance",
                      "dimensional",
                      "other"
                    ],
                    "description": "Broad classification of the deviation."
                  },
                  "type": {
                    "type": "string",
                    "description": "Specific deviation label within the category (free text)."
                  },
                  "description": {
                    "type": "string"
                  },
                  "occurred_at": {
                    "type": [
                      "integer",
                      "string"
                    ]
                  },
                  "duration_s": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "step_index": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "impact": {
                    "type": "string",
                    "enum": [
                      "minor",
                      "moderate",
                      "major"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "measured": {
      "$ref": "cell-canonical.schema.json#/$defs/SpecSet"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "measurement",
            "lab",
            "bms",
            "other"
          ]
        },
        "source_url": {
          "oneOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "citation": {
          "type": "string",
          "format": "uri"
        },
        "citation_doi": {
          "type": "string",
          "pattern": "^10\\.\\d{4,9}/[-._;()/:A-Za-z0-9]+$"
        },
        "retrieved_at": {
          "$ref": "#/$defs/UnixTime"
        },
        "source_name": {
          "type": "string"
        },
        "source_file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "file_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "workflow_version": {
          "type": "string"
        },
        "curated_by": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        }
      }
    },
    "datasets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DatasetLink"
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "funding": {
      "$ref": "#/$defs/Funding"
    },
    "contributor": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Person"
      },
      "minItems": 1,
      "description": "People who contributed this record to the platform (attribution/provenance). Each is a schema:Person; an ORCID may be given in same_as. Distinct from data authorship (creators)."
    }
  },
  "$defs": {
    "UnixTime": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp in whole seconds since 1970-01-01T00:00:00Z."
    },
    "FlexDate": {
      "oneOf": [
        {
          "$ref": "#/$defs/UnixTime"
        },
        {
          "type": "string",
          "description": "ISO 8601 date string (YYYY-MM-DD or YYYY-MM)."
        }
      ]
    },
    "ShortId": {
      "type": "string",
      "pattern": "^[0-9a-hjkmnp-tv-z]{6,16}$"
    },
    "CellIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/cell/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "DatasetIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/dataset/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "DatasetLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/DatasetIri"
        },
        "role": {
          "type": "string",
          "enum": [
            "raw",
            "processed",
            "report",
            "metadata",
            "other"
          ]
        }
      }
    },
    "SpecIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/spec/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "Funding": {
      "type": "object",
      "additionalProperties": false,
      "description": "Funding project (grant) under which the record was produced. Maps to schema:funding / schema:Grant in JSON-LD.",
      "required": [
        "identifier"
      ],
      "properties": {
        "type": {
          "const": "Grant"
        },
        "id": {
          "type": "string",
          "format": "uri"
        },
        "identifier": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "acronym": {
          "type": "string"
        },
        "program": {
          "type": "string"
        },
        "funder": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name"
          ],
          "properties": {
            "type": {
              "const": "Organization"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "same_as": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      }
    },
    "Organization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "Organization"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "same_as": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "Person": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "Person"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "given_name": {
          "type": "string",
          "minLength": 1
        },
        "family_name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "same_as": {
          "type": "string",
          "format": "uri"
        },
        "affiliation": {
          "$ref": "#/$defs/Organization"
        }
      }
    }
  }
}
