{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schema/modules/components/electrolyte.schema.json",
  "title": "Electrolyte",
  "description": "Electrolyte family and composition.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "family"
  ],
  "properties": {
    "family": {
      "type": "string",
      "enum": [
        "organic",
        "aqueous",
        "ionic_liquid",
        "solid",
        "gel",
        "hybrid",
        "unknown"
      ]
    },
    "solvent_mixture": {
      "$ref": "material-mixture.schema.json"
    },
    "salt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "material_spec_id": {
          "type": "string",
          "pattern": "^https://w3id\\.org/battinfo/material-spec/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$",
          "description": "Optional canonical IRI of a standalone material-spec for the salt."
        },
        "cation": {
          "type": "string"
        },
        "anion": {
          "type": "string"
        },
        "manufacturer": {
          "type": "string"
        },
        "supplier": {
          "type": "string"
        },
        "product_id": {
          "type": "string"
        },
        "property": {
          "$ref": "../common/quantitative-properties.schema.json"
        },
        "comment": {
          "type": "string"
        }
      }
    },
    "additive": {
      "type": "array",
      "items": {
        "$ref": "material-component.schema.json"
      }
    },
    "manufacturer": {
      "type": "string"
    },
    "supplier": {
      "type": "string"
    },
    "product_id": {
      "type": "string"
    },
    "property": {
      "$ref": "../common/quantitative-properties.schema.json"
    },
    "comment": {
      "type": "string"
    }
  }
}

