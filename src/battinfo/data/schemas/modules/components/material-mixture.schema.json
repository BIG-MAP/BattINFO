{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schema/modules/components/material-mixture.schema.json",
  "title": "Material Mixture",
  "description": "Mixture of named material components.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "component"
  ],
  "properties": {
    "component": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "material-component.schema.json"
      }
    },
    "property": {
      "$ref": "../common/quantitative-properties.schema.json"
    },
    "comment": {
      "type": "string"
    }
  }
}

