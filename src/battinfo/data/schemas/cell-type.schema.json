{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battinfo/schema/cell-type.schema.json",
  "title": "BattINFO Cell Type (Schema.org-Aligned Product)",
  "description": "Canonical cell-type metadata using schema.org Product terms with minimal battery-specific extensions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "product",
    "specs",
    "provenance"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "product": {
            "properties": {
              "cellFormat": {
                "const": "cylindrical"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "specs": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "length"
                  ]
                },
                {
                  "required": [
                    "width"
                  ]
                },
                {
                  "required": [
                    "thickness"
                  ]
                }
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "product": {
            "properties": {
              "cellFormat": {
                "enum": [
                  "prismatic",
                  "pouch"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "specs": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "diameter"
                  ]
                },
                {
                  "required": [
                    "height"
                  ]
                }
              ]
            }
          }
        }
      }
    }
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "identifier",
        "name",
        "model",
        "manufacturer",
        "cellFormat",
        "chemistry"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/CellTypeIri"
        },
        "short_id": {
          "$ref": "#/$defs/ShortId"
        },
        "identifier": {
          "$ref": "#/$defs/Identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "manufacturer": {
          "$ref": "#/$defs/Organization"
        },
        "brand": {
          "$ref": "#/$defs/BrandOrOrganization"
        },
        "category": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "additionalType": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1,
              "uniqueItems": true
            }
          ]
        },
        "cellFormat": {
          "type": "string",
          "enum": [
            "cylindrical",
            "prismatic",
            "pouch",
            "coin",
            "other",
            "unknown"
          ]
        },
        "sizeCode": {
          "type": "string",
          "pattern": "^[RP][A-Za-z0-9]+(?:[/-][A-Za-z0-9]+)*$"
        },
        "iecCode": {
          "type": "string",
          "minLength": 1
        },
        "countryOfOrigin": {
          "type": "string",
          "minLength": 1
        },
        "year": {
          "type": "integer",
          "minimum": 1800,
          "maximum": 3000
        },
        "chemistry": {
          "type": "string",
          "minLength": 1
        },
        "positiveElectrodeBasis": {
          "type": "string"
        },
        "negativeElectrodeBasis": {
          "type": "string"
        },
        "datasheetRevision": {
          "type": "string"
        }
      }
    },
    "specs": {
      "$ref": "cell-canonical.schema.json#/$defs/SpecSet"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_file",
        "retrieved_at"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "datasheet",
            "label",
            "catalog",
            "manual",
            "other"
          ]
        },
        "source_file": {
          "type": "string"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "citation": {
          "type": "string",
          "format": "uri"
        },
        "citation_doi": {
          "type": "string",
          "pattern": "^10\\.\\d{4,9}/[-._;()/:A-Za-z0-9]+$"
        },
        "file_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "retrieved_at": {
          "$ref": "#/$defs/UnixTime"
        }
      }
    },
    "bibliography": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subject_of": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BibliographyEntry"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "editorial": {
      "type": "object",
      "description": "Internal editorial and review metadata — stored in the source record but not forwarded to the registry semantic payload.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "UnixTime": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp in whole seconds since 1970-01-01T00:00:00Z."
    },
    "BibliographyEntry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "format": "uri"
        },
        "doi": {
          "type": "string",
          "pattern": "^10\\.\\d{4,9}/[-._;()/:A-Za-z0-9]+$"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "headline": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "date_published": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1800,
              "maximum": 3000
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        }
      }
    },
    "ShortId": {
      "type": "string",
      "pattern": "^[0-9a-hjkmnp-tv-z]{6,16}$"
    },
    "CellTypeIri": {
      "type": "string",
      "pattern": "^https://w3id\\.org/battinfo/cell-type/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
    },
    "Identifier": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/PropertyValue"
        },
        {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "$ref": "#/$defs/PropertyValue"
              }
            ]
          },
          "minItems": 1
        }
      ]
    },
    "PropertyValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "property_id",
        "value"
      ],
      "properties": {
        "property_id": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Organization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "Organization"
        },
        "id": {
          "type": "string",
          "pattern": "^https://w3id\\.org/battinfo/organization/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$",
          "description": "Canonical BattINFO organization IRI."
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "Brand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "type": {
          "const": "Brand"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "BrandOrOrganization": {
      "anyOf": [
        {
          "$ref": "#/$defs/Brand"
        },
        {
          "$ref": "#/$defs/Organization"
        }
      ]
    }
  }
}
