{
  "profile_id": "https://w3id.org/battinfo/profile/cell-descriptor",
  "version": "0.1.0-draft",
  "status": "draft",
  "source_of_truth_order": [
    "domain-battery",
    "ontology/battinfo.ttl",
    "src/battinfo/data/profiles/cell-descriptor/profile.json",
    "assets/schemas/cell-descriptor.schema.json",
    "src/battinfo/transform/json_to_jsonld.py"
  ],
  "semantic_policy": {
    "generic_metadata_vocab": "schema.org",
    "battery_semantics_vocab": "domain-battery / EMMO",
    "extension_policy": "avoid BattINFO-specific JSON-LD terms unless no reasonable alternative exists"
  },
  "contract": {
    "top_level": {
      "required": [
        "schema_version",
        "specification"
      ],
      "optional": [
        "instances",
        "provenance",
        "comment"
      ]
    },
    "specification": {
      "required_core": [
        "id",
        "manufacturer",
        "model",
        "format",
        "chemistry",
        "positive_electrode_basis",
        "negative_electrode_basis"
      ],
      "optional_extensions": [
        "size_code",
        "property",
        "positive_electrode",
        "negative_electrode",
        "electrolyte",
        "separator",
        "coin_hardware",
        "comment"
      ]
    },
    "stable_subset": {
      "top_level": [
        "schema_version",
        "specification",
        "instances",
        "provenance",
        "comment"
      ],
      "specification": [
        "id",
        "manufacturer",
        "model",
        "format",
        "chemistry",
        "positive_electrode_basis",
        "negative_electrode_basis",
        "size_code",
        "property",
        "comment"
      ],
      "status": "stable-for-integration"
    }
  },
  "schema_projection": {
    "top_level": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$"
        },
        "specification": {
          "$ref": "modules/components/specification.schema.json"
        },
        "instances": {
          "type": "array",
          "items": {
            "$ref": "modules/components/cell-instance-reference.schema.json"
          }
        },
        "provenance": {
          "$ref": "modules/common/provenance.schema.json"
        },
        "comment": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "specification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^https://w3id\\.org/battinfo/cell-type/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
        },
        "manufacturer": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "enum_from": "controlled_values.specification.format"
        },
        "chemistry": {
          "type": "string",
          "minLength": 1
        },
        "positive_electrode_basis": {
          "type": "string",
          "minLength": 1
        },
        "negative_electrode_basis": {
          "type": "string",
          "minLength": 1
        },
        "size_code": {
          "type": "string"
        },
        "construction": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "assembly_type": {
              "type": "string",
              "enum": [
                "wound",
                "stacked",
                "other",
                "unknown"
              ]
            },
            "layering": {
              "type": "string",
              "enum": [
                "single_layer",
                "multilayer",
                "not_applicable",
                "unknown"
              ]
            },
            "layer_count": {
              "type": "integer",
              "minimum": 1
            },
            "assembly_sequence": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "comment": {
              "type": "string"
            }
          }
        },
        "property": {
          "$ref": "../common/quantitative-properties.schema.json"
        },
        "positive_electrode": {
          "$ref": "electrode.schema.json"
        },
        "negative_electrode": {
          "$ref": "electrode.schema.json"
        },
        "electrolyte": {
          "$ref": "electrolyte.schema.json"
        },
        "separator": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "material"
          ],
          "properties": {
            "material": {
              "type": "string",
              "minLength": 1
            },
            "manufacturer": {
              "type": "string"
            },
            "supplier": {
              "type": "string"
            },
            "product_id": {
              "type": "string"
            },
            "property": {
              "$ref": "../common/quantitative-properties.schema.json"
            },
            "comment": {
              "type": "string"
            }
          }
        },
        "coin_hardware": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "case": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "size_code": {
                  "type": "string"
                },
                "material": {
                  "type": "string"
                },
                "manufacturer": {
                  "type": "string"
                },
                "supplier": {
                  "type": "string"
                },
                "product_id": {
                  "type": "string"
                },
                "lid_coating": {
                  "type": "string"
                },
                "can_coating": {
                  "type": "string"
                },
                "property": {
                  "$ref": "../common/quantitative-properties.schema.json"
                },
                "comment": {
                  "type": "string"
                }
              }
            },
            "lid": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "material": {
                  "type": "string"
                },
                "coating": {
                  "type": "string"
                },
                "manufacturer": {
                  "type": "string"
                },
                "supplier": {
                  "type": "string"
                },
                "product_id": {
                  "type": "string"
                },
                "property": {
                  "$ref": "../common/quantitative-properties.schema.json"
                },
                "comment": {
                  "type": "string"
                }
              }
            },
            "can": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "material": {
                  "type": "string"
                },
                "coating": {
                  "type": "string"
                },
                "manufacturer": {
                  "type": "string"
                },
                "supplier": {
                  "type": "string"
                },
                "product_id": {
                  "type": "string"
                },
                "property": {
                  "$ref": "../common/quantitative-properties.schema.json"
                },
                "comment": {
                  "type": "string"
                }
              }
            },
            "spring": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "material": {
                  "type": "string"
                },
                "manufacturer": {
                  "type": "string"
                },
                "supplier": {
                  "type": "string"
                },
                "product_id": {
                  "type": "string"
                },
                "property": {
                  "$ref": "../common/quantitative-properties.schema.json"
                },
                "comment": {
                  "type": "string"
                }
              }
            },
            "spacer": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "material": {
                  "type": "string"
                },
                "manufacturer": {
                  "type": "string"
                },
                "supplier": {
                  "type": "string"
                },
                "product_id": {
                  "type": "string"
                },
                "property": {
                  "$ref": "../common/quantitative-properties.schema.json"
                },
                "comment": {
                  "type": "string"
                }
              }
            },
            "comment": {
              "type": "string"
            }
          }
        },
        "comment": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "instance_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "pattern": "^https://w3id\\.org/battinfo/cell/[0-9a-hjkmnp-tv-z]{4}(?:-[0-9a-hjkmnp-tv-z]{4}){3}$"
        },
        "serial_number": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_file",
        "retrieved_at"
      ],
      "properties": {
        "source_type": {
          "type": "string"
        },
        "source_name": {
          "type": "string"
        },
        "source_file": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "citation": {
          "type": "string",
          "format": "uri",
          "description": "Resolvable citation target to use for attribution, typically a DOI URL."
        },
        "citation_doi": {
          "type": "string",
          "pattern": "^10\\.\\d{4,9}/[-._;()/:A-Za-z0-9]+$",
          "description": "Deprecated compatibility field. Prefer provenance.citation with a DOI resolver URL."
        },
        "retrieved_at": {
          "type": "integer",
          "minimum": 0
        },
        "workflow_version": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        }
      }
    },
    "quantity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "min_value": {
          "type": "number"
        },
        "max_value": {
          "type": "number"
        },
        "typical_value": {
          "type": "number"
        },
        "value_text": {
          "type": "string",
          "minLength": 1
        },
        "unit_text": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical compact unit symbol/code, for example V, A, Ah, Wh/kg."
        }
      },
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "value"
              ]
            },
            {
              "required": [
                "min_value"
              ]
            },
            {
              "required": [
                "max_value"
              ]
            },
            {
              "required": [
                "typical_value"
              ]
            },
            {
              "required": [
                "value_text"
              ]
            }
          ]
        },
        {
          "anyOf": [
            {
              "required": [
                "unit"
              ]
            },
            {
              "required": [
                "unit_text"
              ]
            }
          ]
        }
      ]
    },
    "quantitative_properties": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "$ref": "quantity.schema.json"
        }
      },
      "additionalProperties": false
    }
  },
  "quantity_model": {
    "human_json_keys": [
      "value",
      "min_value",
      "max_value",
      "typical_value",
      "unit",
      "unit_text"
    ],
    "human_json_semantics": "schema.org QuantitativeValue adapted to snake_case",
    "jsonld_rendering": {
      "property_relation": "hasProperty",
      "property_node_type": "ConventionalProperty",
      "numerical_part_relation": "hasNumericalPart",
      "numerical_value_relation": "hasNumericalValue",
      "unit_relation": "hasMeasurementUnit",
      "text_value_relation": "schema:value",
      "qualifier_relation": "schema:valueReference"
    }
  },
  "field_bindings": {
    "schema_version": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:schemaVersion"
    },
    "specification.id": {
      "kind": "identifier",
      "jsonld_target": "@id"
    },
    "specification.manufacturer": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:manufacturer"
    },
    "specification.model": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:model"
    },
    "specification.format": {
      "kind": "battery_semantic_binding",
      "binding_source": "assets/mappings/domain-battery/entity_type_map.json#/mappings/format",
      "jsonld_target": "@type"
    },
    "specification.chemistry": {
      "kind": "battery_semantic_binding",
      "binding_source": "assets/mappings/domain-battery/entity_type_map.json#/mappings/chemistry",
      "jsonld_target": "@type"
    },
    "specification.positive_electrode_basis": {
      "kind": "battery_semantic_binding",
      "binding_source": "assets/mappings/domain-battery/entity_type_map.json#/mappings/positive_electrode_basis",
      "jsonld_target": "hasPositiveElectrode"
    },
    "specification.negative_electrode_basis": {
      "kind": "battery_semantic_binding",
      "binding_source": "assets/mappings/domain-battery/entity_type_map.json#/mappings/negative_electrode_basis",
      "jsonld_target": "hasNegativeElectrode"
    },
    "specification.size_code": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:size"
    },
    "specification.construction": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:additionalProperty"
    },
    "specification.construction.assembly_type": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:additionalProperty"
    },
    "specification.construction.layering": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:additionalProperty"
    },
    "specification.construction.layer_count": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:additionalProperty"
    },
    "specification.construction.comment": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:additionalProperty"
    },
    "specification.comment": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:description"
    },
    "specification.property": {
      "kind": "battery_semantic_binding",
      "binding_source": "assets/mappings/domain-battery/property_map.candidates.json",
      "jsonld_target": "hasProperty"
    },
    "instances": {
      "kind": "generic_metadata",
      "jsonld_target": "@graph"
    },
    "instances.id": {
      "kind": "identifier",
      "jsonld_target": "@id"
    },
    "instances.name": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:name"
    },
    "instances.serial_number": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:serialNumber"
    },
    "instances.comment": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:description"
    },
    "instances.relation_to_specification": {
      "kind": "generic_metadata",
      "jsonld_target": "hasDescription"
    },
    "provenance": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:isBasedOn"
    },
    "provenance.citation": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:citation"
    },
    "provenance.citation_doi": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:citation"
    },
    "comment": {
      "kind": "generic_metadata",
      "jsonld_target": "schema:description"
    }
  },
  "controlled_values": {
    "specification.format": {
      "values": [
        "cylindrical",
        "prismatic",
        "pouch",
        "coin",
        "other",
        "unknown"
      ],
      "binding_source": "assets/mappings/domain-battery/entity_type_map.json#/mappings/format"
    }
  }
}

